[Unit]
Description=ACHUS - Multi-Tool Home Lab
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=youruser
WorkingDirectory=/home/youruser/achus
ExecStart=/home/youruser/achus/venv/bin/python -m uvicorn app:app --app-dir /home/youruser/achus/backend --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
