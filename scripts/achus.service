[Unit]
Description=ACHUS - Multi-Tool Home Lab
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=sarang
WorkingDirectory=/home/sarang/server/achus
ExecStart=/home/sarang/server/achus/venv/bin/python -m uvicorn app:app --app-dir /home/sarang/server/achus/backend --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=5
Environment=PYTHONPATH=/home/sarang/server/achus

[Install]
WantedBy=multi-user.target
